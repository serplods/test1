```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build directories
dist/
build/
target/
*.jar
*.war
*.zip
*.tar.gz

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs and caches
*.log
*.tmp
*.temp
coverage/
htmlcov/
.coverage
.mypy_cache/
.pytest_cache/

# System files
.DS_Store
Thumbs.db

# Compression and archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```